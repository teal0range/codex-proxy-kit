#!/usr/bin/env bash
set -euo pipefail

PROVIDER="${CODEX_VLLM_PROVIDER:-localvllm}"
PORT="${CODEX_VLLM_LISTEN_PORT:-18011}"
LOG_DIR="${CODEX_VLLM_LOG_DIR:-$HOME/.local/share/codex-vllm-proxy/logs}"
SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
PROXY_BIN="$SCRIPT_DIR/codex_vllm_responses_proxy.py"
CONFIG_PATH="${CODEX_VLLM_MODELS_CONFIG:-$SCRIPT_DIR/../profiles/login002.json}"
INITIAL_MODEL="${CODEX_VLLM_INITIAL_MODEL:-}"
TARGET_MODEL="${CODEX_VLLM_TARGET_MODEL:-kimi-k2.5}"
UPSTREAM="${CODEX_VLLM_UPSTREAM:-http://127.0.0.1:8000}"
PROXY_PID=
TEMP_CONFIG=
COMMON_ARGS=()

# Best-effort cleanup for stale Codex arg0 temp directories left by previous runs.
find "${TMPDIR:-/tmp}" -maxdepth 1 -type d -name 'codex-arg0*' -exec rm -rf {} + 2>/dev/null || true

while [[ $# -gt 0 ]]; do
  case "$1" in
    --provider) PROVIDER="$2"; shift 2 ;;
    --config) CONFIG_PATH="$2"; shift 2 ;;
    --model) INITIAL_MODEL="$2"; shift 2 ;;
    --target-model) TARGET_MODEL="$2"; shift 2 ;;
    --upstream) UPSTREAM="$2"; shift 2 ;;
    --port) PORT="$2"; shift 2 ;;
    --) shift; break ;;
    *) break ;;
  esac
done

mkdir -p "$LOG_DIR"

cleanup() {
  if [[ -n "${PROXY_PID:-}" ]] && kill -0 "$PROXY_PID" 2>/dev/null; then
    kill "$PROXY_PID" >/dev/null 2>&1 || true
    wait "$PROXY_PID" >/dev/null 2>&1 || true
  fi
  if [[ -n "${TEMP_CONFIG:-}" && -f "${TEMP_CONFIG:-}" ]]; then
    rm -f "$TEMP_CONFIG"
  fi
}
trap cleanup EXIT

if [[ ! -f "$CONFIG_PATH" ]]; then
  TEMP_CONFIG="$(mktemp)"
  cat >"$TEMP_CONFIG" <<EOF
{
  "default_model": "${TARGET_MODEL}",
  "models": [
    {
      "name": "${TARGET_MODEL}",
      "target_model": "${TARGET_MODEL}",
      "upstream_base": "${UPSTREAM}"
    }
  ]
}
EOF
  CONFIG_PATH="$TEMP_CONFIG"
fi

if [[ -z "$INITIAL_MODEL" ]]; then
  INITIAL_MODEL="$(python3 - <<PY
import json
from pathlib import Path
cfg = json.loads(Path("$CONFIG_PATH").read_text(encoding="utf-8"))
print(cfg.get("default_model") or cfg["models"][0]["name"])
PY
)"
fi

if ! python3 - <<PY >/dev/null 2>&1
import socket
s = socket.socket()
try:
    s.connect(("127.0.0.1", int("$PORT")))
except OSError:
    raise SystemExit(1)
else:
    raise SystemExit(0)
finally:
    s.close()
PY
then
  "$PROXY_BIN" \
    --models-config "$CONFIG_PATH" \
    --listen-port "$PORT" \
    --log-dir "$LOG_DIR" &
  PROXY_PID=$!
fi

if [[ $# -gt 0 && "$1" == "codex" ]]; then
  shift
fi

COMMON_ARGS=(
  -c "model_provider=\"${PROVIDER}\""
  -c "model_providers.${PROVIDER}.name=\"${PROVIDER}\""
  -c "model_providers.${PROVIDER}.base_url=\"http://127.0.0.1:${PORT}/v1\""
  -c "model_providers.${PROVIDER}.env_key=\"OPENAI_API_KEY\""
  -c 'model_providers.'"${PROVIDER}"'.wire_api="responses"'
  -m "$INITIAL_MODEL"
)

if [[ $# -eq 0 ]]; then
  exec codex "${COMMON_ARGS[@]}"
fi

case "$1" in
  exec|review|resume|help)
    exec codex "${COMMON_ARGS[@]}" "$@"
    ;;
  -*)
    exec codex "${COMMON_ARGS[@]}" "$@"
    ;;
  *)
    exec codex "${COMMON_ARGS[@]}" exec --skip-git-repo-check --dangerously-bypass-approvals-and-sandbox "$@"
    ;;
esac
